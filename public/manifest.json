{
  "manifest_version": 3,
  "name": "WatchDeck",
  "description": "local-first YouTube convenience tools",
  "version": "0.1.0",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
